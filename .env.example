# 데이터베이스 설정
DATABASE_URL=postgresql://username@localhost:5432/odin_db

# API 설정
BID_API_URL=http://apis.data.go.kr/1230000/BidPublicInfoService/getBidPblancListInfoCnstwk
BID_API_KEY=your_api_key_here

# 테스트 모드 설정 (true일 때만 DB/파일 초기화)
TEST_MODE=false

# 배치 설정
BATCH_SIZE=100
MAX_PAGES=10

# 로그 레벨
LOG_LEVEL=INFO

# 이메일 설정
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=ODIN-AI Batch System <your_email@gmail.com>
EMAIL_TO=recipient@example.com,recipient2@example.com
EMAIL_USE_TLS=true