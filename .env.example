# ODIN-AI 환경변수 설정 예제
# 이 파일을 .env로 복사하여 사용하세요

# 데이터베이스
DATABASE_URL=postgresql://blockmeta@localhost:5432/odin_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# 공공데이터포털 API
BID_API_KEY=YOUR_API_KEY_HERE

# 이메일 설정
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=jeromwolf@gmail.com
EMAIL_PASSWORD=YOUR_EMAIL_APP_PASSWORD_HERE
EMAIL_FROM=jeromwolf@gmail.com
EMAIL_TO=jeromwolf7@naver.com

# SMS 설정 (선택)
SMS_API_KEY=

# 배치 설정
TEST_MODE=false
DB_FILE_INIT=false

# 알림 설정
DAEMON_MODE=false
DRY_RUN=false

# JWT 보안 설정
SECRET_KEY=your-secret-key-change-this-in-production

# 토스페이먼츠 결제
TOSS_CLIENT_KEY=test_ck_your_key_here
TOSS_SECRET_KEY=test_sk_your_key_here
PAYMENT_TEST_MODE=true

# 프론트엔드 URL (이메일 링크용)
FRONTEND_URL=http://localhost:3000