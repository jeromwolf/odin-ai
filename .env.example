# 데이터베이스 설정
DATABASE_URL=postgresql://odin_user:password@localhost:5432/odin_ai
REDIS_URL=redis://localhost:6379/0

# JWT 설정
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 공공데이터포털 API
PUBLIC_DATA_API_KEY=your-public-data-portal-api-key
PUBLIC_DATA_BASE_URL=https://www.data.go.kr/

# 나라장터 크롤링 설정
G2B_LOGIN_ID=your-g2b-login-id
G2B_LOGIN_PASSWORD=your-g2b-password
CRAWLER_DELAY_MIN=2
CRAWLER_DELAY_MAX=5
CRAWLER_USER_AGENT=Odin-AI/1.0 (contact@odin-ai.kr)

# AI/ML 설정
OPENAI_API_KEY=your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment

# 이메일 설정
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# 파일 저장 경로
UPLOAD_DIR=./uploaded_files
PROCESSED_DIR=./processed_docs
TEMP_DIR=./temp_files

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=./logs/odin-ai.log

# 개발/프로덕션 설정
ENVIRONMENT=development
DEBUG=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Celery 설정
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 모니터링 (옵션)
SENTRY_DSN=your-sentry-dsn